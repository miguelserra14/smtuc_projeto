from __future__ import annotations

import argparse
import shutil
import zipfile
from pathlib import Path

REQUIRED = {"agency.txt", "stops.txt", "routes.txt", "trips.txt", "stop_times.txt"}
OPTIONAL = {"calendar.txt", "calendar_dates.txt", "shapes.txt"}


def ensure_dir(p: Path) -> None:
    p.mkdir(parents=True, exist_ok=True)


def extract_or_copy(src: Path, dst: Path) -> None:
    ensure_dir(dst)

    if src.is_file() and src.suffix.lower() == ".zip":
        with zipfile.ZipFile(src, "r") as zf:
            names = {Path(n).name for n in zf.namelist()}
            missing = REQUIRED - names
            if missing:
                raise FileNotFoundError(f"GTFS incompleto. Faltam: {', '.join(sorted(missing))}")

            for name in sorted(REQUIRED | OPTIONAL):
                if name in names:
                    # extrai para temp interno e move só o ficheiro final
                    for member in zf.namelist():
                        if Path(member).name == name:
                            target = dst / name
                            with zf.open(member) as src_f, target.open("wb") as dst_f:
                                shutil.copyfileobj(src_f, dst_f)
                            break
    elif src.is_dir():
        files = {p.name for p in src.glob("*.txt")}
        missing = REQUIRED - files
        if missing:
            raise FileNotFoundError(f"GTFS incompleto. Faltam: {', '.join(sorted(missing))}")

        for name in sorted(REQUIRED | OPTIONAL):
            fp = src / name
            if fp.exists():
                shutil.copy2(fp, dst / name)
    else:
        raise ValueError("Origem inválida. Usa uma pasta GTFS ou um ficheiro .zip")


def main() -> None:
    parser = argparse.ArgumentParser(description="Integrar GTFS SMTUC no projeto")
    parser.add_argument("--source", required=True, help="Caminho para GTFS (.zip ou pasta)")
    parser.add_argument(
        "--target",
        default=r"data\gtfs\smtuc",
        help=r"Pasta destino (default: data\gtfs\smtuc)",
    )
    args = parser.parse_args()

    root = Path(__file__).resolve().parents[1]
    source = Path(args.source).expanduser().resolve()
    target = (root / args.target).resolve()

    extract_or_copy(source, target)
    print(f"GTFS integrado em: {target}")


if __name__ == "__main__":
    main()